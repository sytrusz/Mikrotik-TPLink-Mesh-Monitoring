# MikroTik Configuration
MIKROTIK_HOST=192.168.x.x
MIKROTIK_PASS=your_password
MIKROTIK_USE_SSL=false

# ISP 1 (e.g., Converge)
MIKROTIK_WAN1_NAME=ether1-Converge
MIKROTIK_WAN1_LABEL=Converge
MIKROTIK_WAN1_TABLE=to-WAN1

# ISP 2 (e.g., PLDT)
MIKROTIK_WAN2_NAME=ether2-PLDT
MIKROTIK_WAN2_LABEL=PLDT
MIKROTIK_WAN2_TABLE=to-WAN2

# Deco Configuration
DECO_HOST=192.168.x.x
DECO_PASS=your_deco_web_password

# Mesh Nodes
NODE1_NAME=Main - Living Room
NODE2_IP=192.168.x.x
NODE2_NAME=Garden
NODE3_IP=192.168.x.x
NODE3_NAME=Bedroom

# Dashboard Settings
PORT=8000
DEBUG=false